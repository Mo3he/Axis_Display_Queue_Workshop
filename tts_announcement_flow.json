    {
        "id": "tts-build-url",
        "type": "function",
        "z": "workshop-tts-flow",
        "name": "Build TTS URL",
        "func": "const orderNumber = msg.payload;\nconst text = `Order number ${orderNumber} is ready for pickup`;\nconst encoded = encodeURIComponent(text);\n\nmsg.url = `https://translate.google.com/translate_tts?ie=UTF-8&client=tw-ob&tl=en&q=${encoded}`;\nmsg.headers = { 'User-Agent': 'Mozilla/5.0' };\nmsg.method = 'GET';\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
