    },
    {
        "id": "tts-parse-clip-id",
        "type": "function",
        "z": "workshop-tts-flow",
        "name": "Parse Clip ID & Play",
        "func": "// Response is like \"OK\\nUploaded=3\" or \"OK\\nReplaced=3\"\nconst response = msg.payload;\nconst match = response.match(/(?:Uploaded|Replaced)=(\\d+)/);\n\nif (match) {\n    const clipId = match[1];\n    msg.url = `http://10.129.174.195/axis-cgi/mediaclip.cgi?action=play&clip=${clipId}`;\n    msg.method = 'GET';\n    msg.headers = {};\n    msg.payload = null;\n    return msg;\n}\n\nnode.error('Failed to parse clip ID from: ' + response);\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
