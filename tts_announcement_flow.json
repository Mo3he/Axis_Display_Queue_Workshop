    {
        "id": "tts-build-upload",
        "type": "function",
        "z": "workshop-tts-flow",
        "name": "Build Upload",
        "func": "const boundary = '----NodeREDFormBoundary';\nconst filename = 'tts_announcement.mp3';\n\n// msg.payload contains MP3 binary from Google TTS\nconst audioBuffer = msg.payload;\n\n// Construct multipart form body\nconst header = Buffer.from(\n    `--${boundary}\\r\\n` +\n    `Content-Disposition: form-data; name=\"file\"; filename=\"${filename}\"\\r\\n` +\n    `Content-Type: audio/mpeg\\r\\n\\r\\n`\n);\nconst footer = Buffer.from(`\\r\\n--${boundary}--\\r\\n`);\n\nmsg.payload = Buffer.concat([header, audioBuffer, footer]);\nmsg.headers = {\n    'Content-Type': `multipart/form-data; boundary=${boundary}`\n};\nmsg.url = 'http://10.129.174.195/axis-cgi/mediaclip.cgi?action=upload';\nmsg.method = 'POST';\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 720,
        "y": 200,
        "wires": [["tts-http-upload"]]
    },
